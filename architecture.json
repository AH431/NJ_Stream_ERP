        { "method": "POST", "path": "/inventory/cancel-reserve", "auth": true, "roles": ["sales", "admin"], "description": "Release reserved quantity" }
      ],
      "customer_interactions": [
        { "method": "GET", "path": "/customer-interactions", "auth": true, "roles": ["sales", "warehouse", "admin"], "description": "CRM interaction history for a customer" },
        { "method": "POST", "path": "/customer-interactions", "auth": true, "roles": ["sales", "admin"], "description": "Log visit/call/email interaction" }
