  "offline_sync": {
    "protocol_version": "1.6",
    "spec_doc": "docs/NJ_Stream_ERP MVP 同步協定規格 v1.6.md",
    "adr_docs": [
      "docs/adr/ADR-001-lww-conflict-resolution.md",
      "docs/adr/ADR-002-offline-id-chain-remap.md"
    ],
    "flow": [
      "1. All mutations → PendingOperations table (status: pending)",
      "2. On connectivity, SyncProvider.performSync() batches ≤50 ops by created_at ASC",
      "3. POST /api/v1/sync/push with JWT",
      "4. Server: idempotency check → process in transaction → update processed_operations",
      "5. Partial success: some ops can fail; server returns { succeeded, failed }",
      "6. Frontend: update local state, remap negative local IDs to real server IDs"
    ],
    "local_id_remap": "Negative IDs until server assigns real IDs. Batch-internal FKs updated after parent create succeeds.",
    "conflict_resolution": "LWW (Last-Write-Wins) — if client.updatedAt < server.updatedAt → reject with DATA_CONFLICT → client force-pulls",
    "entity_types": ["customer", "product", "quotation", "sales_order", "inventory_delta", "customer_interaction"],
    "operation_types": ["create", "update", "delete", "delta_update"],
    "delta_types": ["reserve", "cancel", "out", "in"]
  },

  "deployment": {
    "dev": {
      "command": "docker compose up -d (postgres only)",
      "file": "docker-compose.yml"
    },
    "prod": {
      "command": "docker compose -f docker-compose.prod.yml --env-file .env.production up -d",
      "file": "docker-compose.prod.yml",
      "services": ["postgres", "migrate (one-shot)", "ai_service", "backend"],
      "network": "nj-erp-net (internal bridge)",
      "volumes": ["postgres_data", "chroma_data"],
      "resource_limits": {
        "ai_service": { "cpu": "2.0", "memory": "2GB" },
        "backend": { "cpu": "1.0", "memory": "512MB" }
      },
      "tunnel": "Cloudflare Tunnel → localhost:3000"
    }
  },

  "fcm_push": {
    "library": "firebase_messaging 15.0.0",
    "token_registration": "POST /api/v1/notifications/token on login",
    "token_deregistration": "DELETE /api/v1/notifications/token on logout",
    "background_handler": "FcmService.initialize() before Firebase.initializeApp()",
    "trigger": "AnomalyScanner sends FCM for critical severity anomalies",
    "ui": "Anomaly bell (AppBar top-right) → NotificationScreen"
  },

  "conventions_for_new_features": {
    "adding_a_backend_route": [
      "1. Create route file in src/routes/<feature>.route.ts",
      "2. Register in src/app.ts with prefix /api/v1/<feature>",
      "3. Add role guard in auth.plugin.ts or inline with preHandler",
      "4. If modifying data: add entity type to /sync/push handler OR create direct REST endpoint",
      "5. Add rate limit if the endpoint is user-facing or CPU-heavy",
      "6. Add health-check-compatible design — no side effects on GET /health"
    ],
    "adding_a_database_table": [
      "1. Add table definition to packages/backend/src/db/schema.ts",
      "2. Run: npm run db:generate && npm run db:migrate",
      "3. Add soft-delete (deletedAt) for master data tables",
      "4. Use numeric(12,2) for all monetary columns",
      "5. Use timestamp with timezone for all time columns",
      "6. Add corresponding Drift table in packages/frontend/lib/database/"
    ],
    "adding_a_flutter_screen": [
      "1. Create screen in packages/frontend/lib/screens/<feature>/",
      "2. Create Provider if needed in lib/providers/<feature>_provider.dart",
      "3. Register Provider in MultiProvider in lib/main.dart",
      "4. Register route in MaterialApp routes or use Navigator.push",
      "5. If screen modifies data: add PendingOperation via SyncProvider",
      "6. Use Decimal type for all monetary display (never double)"
    ],
    "adding_sync_support_for_new_entity": [
      "1. Add entity type string to supported list in /sync/push handler",
      "2. Add case to switch statement in sync route processing logic",
      "3. Add idempotency check against processed_operations",
      "4. Add local Drift table + DAO + PendingOperation logic in Flutter",
      "5. Document in sync protocol spec doc"
    ],
    "roles": {
      "sales": "Can read all, create/update customers+quotations+orders, cannot delete or manage products",
      "warehouse": "Can read all, ship orders, receive stock; cannot create customers or quotations",
      "admin": "Full access including delete, product management, AR, CSV import, user management"
    },
    "monetary_values": "Always use numeric(12,2) in DB, serialize as string in JSON, use Decimal in Dart. Never use float/double.",
    "soft_delete_pattern": "Set deletedAt = now() instead of DELETE. All list queries must filter WHERE deletedAt IS NULL.",
    "idempotency_pattern": "Generate UUID v4 operationId client-side. Backend checks processed_operations before processing.",
    "error_codes": {
      "FORBIDDEN_OPERATION": "Role does not permit this action",
      "INSUFFICIENT_STOCK": "Inventory check failed for reserve/out delta",
      "DATA_CONFLICT": "LWW conflict — client has stale data",
      "ENTITY_NOT_FOUND": "Referenced entity does not exist or is soft-deleted",
      "DUPLICATE_OPERATION": "operationId already in processed_operations (idempotency)"
    }
  },

