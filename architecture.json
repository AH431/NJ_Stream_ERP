        { "method": "GET", "path": "/analytics/profit", "auth": true, "roles": ["sales", "warehouse", "admin"], "params": "?months=6", "description": "Gross profit trend" },
        { "method": "GET", "path": "/analytics/customers/heatmap", "auth": true, "roles": ["sales", "warehouse", "admin"], "params": "?months=6&limit=10", "description": "Customer activity heatmap" },
        { "method": "GET", "path": "/analytics/funnel", "auth": true, "roles": ["sales", "warehouse", "admin"], "params": "?days=30", "description": "Quote → Order → Shipped conversion funnel" },
        { "method": "GET", "path": "/analytics/inventory/trend", "auth": true, "roles": ["sales", "warehouse", "admin"], "description": "Stock turnover metrics" }
      ],
      "ar": [
        { "method": "GET", "path": "/ar/summary", "auth": true, "roles": ["admin"], "description": "AR aging buckets (0-30/31-60/61-90/90+ days overdue)" },
        { "method": "GET", "path": "/ar/orders", "auth": true, "roles": ["admin"], "description": "Unpaid order list with aging days" },
        { "method": "PUT", "path": "/ar/orders/:id/payment", "auth": true, "roles": ["admin"], "description": "Mark order paid or written-off" }
      ],
      "anomalies": [
        { "method": "GET", "path": "/anomalies", "auth": true, "roles": ["sales", "warehouse", "admin"], "description": "List unresolved alerts" },
        { "method": "POST", "path": "/anomalies/scan", "auth": true, "roles": ["admin"], "description": "Manually trigger anomaly scan (dev/test)" },
