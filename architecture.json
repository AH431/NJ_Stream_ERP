{
  "meta": {
    "project": "NJ_Stream_ERP",
    "generated": "2026-05-16",
    "version": "1.1.0",
    "description": "Architecture reference for agents working on new features. Read conventions carefully before adding routes or screens."
  },

  "services": {
    "backend": {
      "technology": "Fastify 5.0 + Drizzle ORM 0.45 + TypeScript 5.6 + PostgreSQL 16",
      "port": 3000,
      "root": "packages/backend",
      "entry": "src/index.ts",
      "app_factory": "src/app.ts",
      "api_prefix": "/api/v1",
      "auth": {
        "algorithm": "HS256",
        "access_token_ttl": "1h",
        "refresh_token_ttl": "30d",
        "plugin": "src/plugins/auth.plugin.ts"
      },
      "rate_limits": {
        "global": "50 req/min",
        "login": "10 req/min per IP",
        "ai_chat": "10 req/min per user",
        "health": "10 req/min"
      },
      "plugins": [
        "src/plugins/db.ts",
        "src/plugins/auth.plugin.ts"
      ],
      "scripts": {
        "dev": "tsx watch src/index.ts",
        "build": "tsc -p tsconfig.json && tsc-alias",
        "start": "node dist/index.js",
        "db:generate": "drizzle-kit generate",
        "db:studio": "drizzle-kit studio",
        "db:migrate": "drizzle-kit migrate",
        "test": "vitest run --pool=threads",
        "seed:phone-demo": "node ... seed-phone-demo-en.ts"
      }
    },
    "frontend": {
      "technology": "Flutter 3.29+ + Drift 2.29 (SQLite) + Provider 6.1 + Dio 5.7",
      "root": "packages/frontend",
      "entry": "lib/main.dart",
      "state_management": "Provider",
      "http_client": "Dio",
      "local_db": "Drift (SQLite)",
      "key_dependencies": {
        "drift": "2.29.0",
        "provider": "6.1.0",
        "dio": "5.7.0",
        "firebase_messaging": "15.0.0",
        "fl_chart": "0.69.0",
        "decimal": "3.0.0"
      }
    },
    "ai_service": {
      "technology": "FastAPI 0.115 + LangChain + Ollama + ChromaDB",
      "port": 8000,
      "root": "packages/ai_service",
      "entry": "main.py",
      "default_model": "llama3.2:3b",
      "internal_auth": "X-Internal-Token header",
      "endpoints": [
        { "method": "GET", "path": "/health", "description": "Health check" },
        { "method": "POST", "path": "/chat", "description": "SSE streaming chat response", "auth": "X-Internal-Token" }
      ],
      "key_files": {
        "api": "src/api/chat.py",
        "router": "src/router/query_router.py",
        "tools": "src/tools/erp_tools.py",
        "retriever": "src/rag/retriever.py",
        "llm": "src/llm/ollama_client.py",
        "vectorstore": "src/indexing/vectorstore.py",
        "card_generator": "src/indexing/card_generator.py"
      },
      "env_vars": {
        "AI_SERVICE_INTERNAL_TOKEN": "Mutual auth token with backend",
        "FASTIFY_INTERNAL_URL": "Backend URL for ERP data queries",
        "OLLAMA_BASE_URL": "Ollama service address",
        "OLLAMA_MODEL": "LLM model name",
        "CHROMA_DB_PATH": "Vector store directory",
        "DB_READONLY_URL": "PostgreSQL read-only connection",
        "AI_FAKE_LLM": "Test mode flag"
      }
    }
  },

  "database": {
    "engine": "PostgreSQL 16",
    "orm": "Drizzle ORM (backend) / Drift (Flutter local SQLite)",
    "schema_location": "packages/backend/src/schemas/*.schema.ts",
    "conventions": {
      "soft_delete": "All master tables have deletedAt column; queries filter WHERE deletedAt IS NULL",
      "timestamps": "timestamp(..., withTimezone: true, mode: 'date') → JavaScript Date → ISO-8601 JSON",
      "numeric_precision": "numeric(12, 2) for all prices → serialized as string '158000.00' → Decimal type in frontend",
      "idempotency": "UUID v4 operationId stored in processed_operations to prevent duplicate processing"
    },
    "tables": [
      {
        "name": "users",
        "purpose": "Authentication and role-based access control",
        "key_columns": ["id", "username (UNIQUE)", "password (bcrypt hash)", "role (sales|warehouse|admin)", "refreshToken", "isActive"],
        "notes": "bcrypt rounds=12; role is used by auth.plugin.ts for endpoint guards"
      },
      {
        "name": "customers",
        "purpose": "Customer master data with soft-delete",
        "key_columns": ["id", "name", "contact", "email", "taxId", "paymentTermsDays", "deletedAt"],
        "soft_delete": true
      },
      {
        "name": "products",
        "purpose": "Product catalog with soft-delete",
        "key_columns": ["id", "name", "sku (UNIQUE)", "unitPrice numeric(12,2)", "costPrice numeric(12,2)", "minStockLevel", "deletedAt"],
        "soft_delete": true
      },
      {
        "name": "quotations",
        "purpose": "Sales quotations",
        "key_columns": ["id", "customerId (FK customers)", "createdBy (FK users)", "totalAmount", "taxAmount", "status (draft|sent|converted|expired)", "convertedToOrderId", "deletedAt"],
        "soft_delete": true
      },
      {
        "name": "sales_orders",
        "purpose": "Confirmed sales orders with payment tracking",
        "key_columns": ["id", "quotationId (FK quotations)", "customerId (FK customers)", "createdBy (FK users)", "status (pending|confirmed|shipped|cancelled)", "paymentStatus (unpaid|paid|written_off)", "confirmedAt", "shippedAt", "paidAt", "dueDate", "deletedAt"],
        "soft_delete": true
      },
      {
        "name": "order_items",
        "purpose": "Line items shared between quotations and orders",
        "key_columns": ["id", "quotationId (nullable FK)", "salesOrderId (nullable FK)", "productId (FK products)", "quantity", "unitPrice numeric(12,2)", "subtotal numeric(12,2)"]
      },
      {
        "name": "inventory_items",
        "purpose": "Stock snapshot per warehouse-product combination",
        "key_columns": ["id", "productId (UNIQUE FK products)", "warehouseId", "quantityOnHand (CHECK >= 0)", "quantityReserved (CHECK <= quantityOnHand)", "minStockLevel", "alertStockLevel", "criticalStockLevel"],
        "constraints": ["quantityOnHand >= 0", "quantityReserved <= quantityOnHand"]
      },
      {
        "name": "processed_operations",
        "purpose": "Sync idempotency log and audit trail",
        "key_columns": ["id", "operationId (UUID, UNIQUE)", "entityType", "operationType", "deltaType", "payload (JSONB)", "status (success|failed)", "errorMessage", "processedAt"],
        "retention": "30-day auto-cleanup via /admin/cleanup"
      },
      {
        "name": "anomalies",
        "purpose": "System alerts and exceptions",
        "key_columns": ["id", "alertType", "severity (critical|high|medium)", "entityType", "entityId", "message", "detail (JSONB)", "isResolved", "createdAt"]
      },
      {
        "name": "customer_interactions",
        "purpose": "CRM notes — visits, calls, emails",
        "key_columns": ["id", "customerId (FK customers)", "note", "createdBy (FK users)", "createdAt"]
      },
      {
        "name": "device_tokens",
        "purpose": "FCM push notification tokens",
        "key_columns": ["userId (FK users)", "token (UNIQUE)", "platform (android|ios)", "createdAt"]
      },
      {
        "name": "audit_logs",
        "purpose": "AI chat, tool call, blocked query, and admin import audit trail (separate from processed_operations)",
        "key_columns": ["id", "requestId (UUID, one per ai.chat session)", "userId (FK users)", "userRole", "action (ai.chat|ai.tool_call|ai.blocked|admin.import)", "resourceType", "resourceId", "questionHash (SHA-256)", "toolName", "status (pending|success|denied|blocked|error)", "errorMessage", "meta (JSONB)", "createdAt", "finishedAt"],
        "notes": "Written by audit.service.ts only. Never shared with processed_operations."
      }
    ]
  },

  "api_routes": {
    "prefix": "/api/v1",
    "auth_header": "Authorization: Bearer <access_token>",
    "routes": {
      "auth": [
        { "method": "POST", "path": "/auth/login", "auth": false, "roles": "all", "rate_limit": "10/min/IP", "description": "Returns JWT access + refresh tokens" },
        { "method": "POST", "path": "/auth/refresh", "auth": false, "roles": "all", "description": "Refresh access token" },
        { "method": "POST", "path": "/auth/logout", "auth": true, "roles": "all", "description": "Invalidate refresh token" }
      ],
      "sync": [
        {
          "method": "POST",
          "path": "/sync/push",
          "auth": true,
          "roles": ["sales", "warehouse", "admin"],
          "description": "Offline-first batch operation push (max 50 ops per request)",
          "supported_entity_types": ["customer", "product", "quotation", "sales_order", "inventory_delta", "customer_interaction"],
          "supported_operation_types": ["create", "update", "delete", "delta_update"],
          "supported_delta_types": ["reserve", "cancel", "out", "in"],
          "response": "{ succeeded: [id, ...], failed: [{ id, code, message }, ...] }",
          "conflict_resolution": "LWW (Last-Write-Wins) — reject if client updatedAt < server updatedAt"
        }
      ],
      "customers": [
        { "method": "GET", "path": "/customers", "auth": true, "roles": ["sales", "warehouse", "admin"], "description": "List customers (excludes soft-deleted)" },
        { "method": "GET", "path": "/customers/search", "auth": true, "roles": ["sales", "admin"], "params": "?q=<string>", "description": "CRM search for AI tools and sales workflows. warehouse role → 403." },
        { "method": "GET", "path": "/customers/:id", "auth": true, "roles": ["sales", "warehouse", "admin"], "description": "Customer detail with RFM scoring" },
        { "method": "POST", "path": "/customers", "auth": true, "roles": ["sales", "admin"], "description": "Create customer" },
        { "method": "PUT", "path": "/customers/:id", "auth": true, "roles": ["sales", "admin"], "description": "Update customer (PATCH semantics)" },
        { "method": "DELETE", "path": "/customers/:id", "auth": true, "roles": ["admin"], "description": "Soft-delete customer" },
        { "method": "DELETE", "path": "/customers", "auth": true, "roles": ["admin"], "description": "Batch soft-delete" }
      ],
      "products": [
        { "method": "GET", "path": "/products", "auth": true, "roles": ["sales", "warehouse", "admin"], "description": "List products (excludes soft-deleted)" },
        { "method": "GET", "path": "/products/search", "auth": true, "roles": ["sales", "warehouse", "admin"], "params": "?q=<string>", "description": "Full-text search on name and SKU (ILIKE). Must be registered before /:id route." },
        { "method": "GET", "path": "/products/:id", "auth": true, "roles": ["sales", "warehouse", "admin"], "description": "Product detail" },
        { "method": "POST", "path": "/products", "auth": true, "roles": ["admin"], "description": "Create product" },
        { "method": "PUT", "path": "/products/:id", "auth": true, "roles": ["admin"], "description": "Update product" },
        { "method": "DELETE", "path": "/products/:id", "auth": true, "roles": ["admin"], "description": "Soft-delete product" },
        { "method": "DELETE", "path": "/products", "auth": true, "roles": ["admin"], "description": "Batch soft-delete" }
      ],
      "quotations": [
        { "method": "GET", "path": "/quotations/:id", "auth": true, "roles": ["sales", "warehouse", "admin"], "description": "Quotation detail with order_items + product relations" },
        { "method": "POST", "path": "/quotations/:id/convert-to-order", "auth": true, "roles": ["sales", "admin"], "description": "Convert quotation to sales order (first-to-sync wins)" }
      ],
      "sales_orders": [
        { "method": "GET", "path": "/sales-orders", "auth": true, "roles": ["sales", "warehouse", "admin"], "description": "List sales orders" },
        { "method": "GET", "path": "/sales-orders/:id", "auth": true, "roles": ["sales", "warehouse", "admin"], "description": "Order detail with items" },
        { "method": "POST", "path": "/sales-orders/confirm", "auth": true, "roles": ["sales", "admin"], "description": "Confirm order (locks inventory via reserve delta)" },
        { "method": "POST", "path": "/sales-orders/:id/ship", "auth": true, "roles": ["warehouse", "admin"], "description": "Mark shipped (inventory out delta)" },
        { "method": "POST", "path": "/sales-orders/:id/cancel", "auth": true, "roles": ["sales", "admin"], "description": "Cancel order (releases reserved inventory)" }
      ],
      "inventory": [
