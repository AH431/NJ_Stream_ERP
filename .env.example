# =============================================================================
# NJ_Stream_ERP — 環境變數範本
# 複製此檔為 .env 並填入實際值（.env 已加入 .gitignore）
# =============================================================================

# ---------------- 後端（packages/backend） ----------------

# PostgreSQL 連線
DATABASE_URL=postgresql://postgres:password@localhost:5432/nj_stream_erp

# JWT
JWT_SECRET=change_me_in_production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# 伺服器
PORT=3000
NODE_ENV=development

# ---------------- 前端（packages/frontend） ----------------
# Flutter 不讀 .env；使用 --dart-define 傳入
# 範例：flutter run --dart-define=API_BASE_URL=http://192.168.1.100:3000
#
# API_BASE_URL=http://localhost:3000
