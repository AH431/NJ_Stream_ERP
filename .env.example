# =============================================================================
# NJ_Stream_ERP — 環境變數範本
# 複製此檔為 .env 並填入實際值（.env 已加入 .gitignore）
# =============================================================================

# ---------------- 後端（packages/backend） ----------------

# PostgreSQL / Docker Compose
POSTGRES_DB=nj_erp
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_me_in_local_env
POSTGRES_PORT=5432
POSTGRES_BIND_ADDRESS=127.0.0.1

# PostgreSQL 連線
DATABASE_URL=postgresql://postgres:change_me_in_local_env@localhost:5432/nj_erp

# JWT
JWT_SECRET=change_me_in_production
JWT_ACCESS_EXPIRES_IN=3600
JWT_REFRESH_EXPIRES_IN=2592000

# 伺服器
HOST=127.0.0.1
PORT=3000
NODE_ENV=development

# ---------------- 前端（packages/frontend） ----------------
# Flutter 不讀 .env；使用 --dart-define 傳入
# 範例：flutter run --dart-define=API_BASE_URL=http://192.168.1.100:3000
#
# API_BASE_URL=http://localhost:3000
