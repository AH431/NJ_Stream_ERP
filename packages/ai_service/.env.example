# LLM 設定
OLLAMA_MODEL=llama3.2:3b
OLLAMA_NUM_CTX=8192
OLLAMA_TEMPERATURE=0.3

# Embedding 設定（推薦：bge-m3，備選：nomic-embed-text, mxbai-embed-large）
EMBEDDING_MODEL=bge-m3

# ChromaDB 設定
CHROMA_DB_PATH=./db

# RAG 設定
TOP_K=3
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# 顯存安全閾值 (GB)
VRAM_THRESHOLD=5.5

# Phase 3 新增（FastAPI 整合時填入）
# JWT_SECRET=              # 與 packages/backend/.env 相同值
# FASTIFY_INTERNAL_URL=http://localhost:3000
# OLLAMA_URL=http://localhost:11434
# DATABASE_URL=postgresql://...
