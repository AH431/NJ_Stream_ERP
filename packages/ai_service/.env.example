# ── Log 格式（production 必須設 json，requestId/jobId 才能 grep 跨服務追蹤）──
LOG_FORMAT=json

# ── Phase 3 服務間通訊 ──────────────────────────────────────
# 與 backend 共用，由 openssl rand -hex 32 產生，不得少於 32 字元
AI_SERVICE_INTERNAL_TOKEN=

# true 時不呼叫 Ollama，回傳固定 fake token stream（CI / 開發用）
AI_FAKE_LLM=false

# Fastify backend 內部位址（Docker network 內使用）
FASTIFY_INTERNAL_URL=http://backend:3000/api/v1

# ── LLM 設定 ───────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_NUM_CTX=8192
OLLAMA_TEMPERATURE=0.3

# ── Embedding 設定 ─────────────────────────────────────────
EMBEDDING_MODEL=mxbai-embed-large

# ── ChromaDB 設定 ──────────────────────────────────────────
CHROMA_DB_PATH=/data/chroma

# ── RAG 設定 ───────────────────────────────────────────────
TOP_K=3
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# ── Indexing job（card_generator.py 使用唯讀帳號）──────────
DB_READONLY_URL=

# ── 顯存安全閾值 (GB) ─────────────────────────────────────
VRAM_THRESHOLD=5.5

# ── 需求預測設定（Phase 4B PR-3）─────────────────────────
# Fastify / PostgreSQL 完整連線字串（含寫入權限，供 forecast engine 使用）
DATABASE_URL=postgresql://user:pass@localhost:5432/njstream
FORECAST_WEEKS_AHEAD=12
FORECAST_MIN_DATA_WEEKS=8
FORECAST_JOB_LEASE_SECONDS=900
# true 時略過 Prophet/pandas，回傳亂數預測（Windows 本地開發用）
FORECAST_FAKE_PROPHET=false
# 空白分隔或逗號分隔的內部 API scope 清單
AI_INTERNAL_SCOPES=analytics.read,forecast.generate
