# ── Phase 3 服務間通訊 ──────────────────────────────────────
# 與 backend 共用，由 openssl rand -hex 32 產生，不得少於 32 字元
AI_SERVICE_INTERNAL_TOKEN=

# true 時不呼叫 Ollama，回傳固定 fake token stream（CI / 開發用）
AI_FAKE_LLM=false

# Fastify backend 內部位址（Docker network 內使用）
FASTIFY_INTERNAL_URL=http://backend:3000

# ── LLM 設定 ───────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
OLLAMA_NUM_CTX=8192
OLLAMA_TEMPERATURE=0.3

# ── Embedding 設定 ─────────────────────────────────────────
EMBEDDING_MODEL=bge-m3

# ── ChromaDB 設定 ──────────────────────────────────────────
CHROMA_PATH=/data/chroma

# ── RAG 設定 ───────────────────────────────────────────────
TOP_K=3
CHUNK_SIZE=800
CHUNK_OVERLAP=100

# ── Indexing job（card_generator.py 使用唯讀帳號）──────────
DB_READONLY_URL=

# ── 顯存安全閾值 (GB) ─────────────────────────────────────
VRAM_THRESHOLD=5.5
