# NJ_Stream_ERP Backend — 環境變數範本
# 複製此檔案為 .env 並填入實際值

# Database（對應 docker-compose.yml）
DATABASE_URL=postgresql://postgres:postgres123@localhost:5432/nj_erp

# Server
HOST=0.0.0.0
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRES_IN=3600
JWT_REFRESH_EXPIRES_IN=2592000
