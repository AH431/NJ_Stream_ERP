# NJ_Stream_ERP Backend — 環境變數範本
# 複製此檔案為 .env 並填入實際值

# Database（對應 docker-compose.yml）
DATABASE_URL=postgresql://postgres:change_me_in_local_env@localhost:5432/nj_erp

# Server
HOST=127.0.0.1
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRES_IN=3600
JWT_REFRESH_EXPIRES_IN=2592000

# 公司資訊（報價單 PDF 抬頭）
COMPANY_NAME=NJ Stream
COMPANY_ADDRESS=台北市...
COMPANY_PHONE=02-XXXX-XXXX
COMPANY_EMAIL=contact@example.com
COMPANY_TAX_ID=
