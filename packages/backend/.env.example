# NJ_Stream_ERP Backend — 環境變數範本
# 複製此檔案為 .env 並填入實際值

# Database（對應 docker-compose.yml）
DATABASE_URL=postgresql://postgres:change_me_in_local_env@localhost:5432/nj_erp

# Server
HOST=127.0.0.1
PORT=3000
NODE_ENV=development

# JWT
JWT_SECRET=change-me-in-production
JWT_ACCESS_EXPIRES_IN=3600
JWT_REFRESH_EXPIRES_IN=2592000

# SMTP（文件 Email 寄送）
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=your@gmail.com

# FCM（Firebase Cloud Messaging）
# 從 Firebase Console → 專案設定 → 服務帳戶 → 產生新的私密金鑰 取得 JSON
# 將 JSON 整個壓成一行後貼入（不要換行）
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk-xxx@your-project.iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# 公司資訊（報價單 PDF 抬頭）
COMPANY_NAME=NJ Stream
COMPANY_ADDRESS=台北市...
COMPANY_PHONE=02-XXXX-XXXX
COMPANY_EMAIL=contact@example.com
COMPANY_TAX_ID=
