{
  "name": "@nj-stream-erp/backend",
  "version": "0.1.0",
  "private": true,
  "description": "NJ_Stream_ERP MVP Backend - Fastify + Drizzle ORM",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc-alias",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "db:generate": "node ./scripts/prepare-drizzle-schema.js && drizzle-kit generate --config drizzle.config.js",
    "db:studio": "node ./scripts/prepare-drizzle-schema.js && drizzle-kit studio --config drizzle.config.js",
    "db:migrate": "node ./scripts/run-drizzle-migrate.js",
    "db:migrate:guarded": "powershell -ExecutionPolicy Bypass -File ../../scripts/migrate_with_log.ps1",
    "seed:phone-demo": "node ./node_modules/tsx/dist/cli.mjs ./scripts/seed-phone-demo-en.ts",
    "test": "vitest run --pool=threads"
  },
  "dependencies": {
    "@fastify/cors": "^10.0.0",
    "@fastify/env": "^5.0.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^10.0.0",
    "@fastify/rate-limit": "^10.3.0",
    "bcryptjs": "^3.0.3",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.0.0",
    "firebase-admin": "^13.8.0",
    "jsonwebtoken": "^9.0.3",
    "nodemailer": "^8.0.5",
    "pdfkit": "^0.18.0",
    "pino": "^9.0.0",
    "pino-pretty": "^13.0.0",
    "postgres": "^3.4.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pdfkit": "^0.17.6",
    "@typescript-eslint/eslint-plugin": "^8.0.0",
    "@typescript-eslint/parser": "^8.0.0",
    "drizzle-kit": "^0.28.0",
    "eslint": "^9.0.0",
    "tsc-alias": "^1.8.10",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
