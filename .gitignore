資料版本迭代/
.claude/

# Dependencies
node_modules/
# 專案使用 pnpm，npm lockfile 不納入版控
package-lock.json

# Environment（含密碼、JWT Secret 等）
.env
.env.local
.env.*.local
.env.development
.env.production
**/.env
**/.env.local
!**/.env.example

# Build output
dist/

# Drizzle migrations（generated，含 DB schema 快照）
packages/backend/drizzle/*.sql
packages/backend/drizzle/meta/

# 敏感設定檔（含 DB 密碼、腳本等）
docker-compose.yml
docker-compose.*.yml
setup_gh_tasks.sh

# 系統 / IDE
.DS_Store
Thumbs.db
*.pem
*.key
*.p12
*.pfx

# Flutter / Dart
.dart_tool/
.packages
.pub-cache/
.pub/
build/
.flutter-plugins
.flutter-plugins-dependencies

# Drift / Code generation
# *.g.dart  ← 暫時 commit generated files；決定不 commit 時再取消註解

# Android / iOS build
android/.gradle/
android/app/build/
ios/Flutter/Flutter.framework
ios/Flutter/Flutter.podspec
ios/Flutter/Generated.xcconfig
ios/Runner.xcworkspace/
ios/build/
ios/.symlinks/

# 日誌與快取
*.log
logs/

# 測試 / 本地 SQLite DB（避免把本機資料 push 上去）
**/*.sqlite
**/*.db

# 暫存 scratch 實驗腳本（不應進版控）
scratch_*.ts
scratch_*.dart

# Editor
.idea/
.vscode/
*.iml
