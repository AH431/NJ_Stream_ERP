# =============================================================================
# NJ_Stream_ERP — 生產環境變數範本
# cp .env.production.example .env.production 並填入實際值
# 啟動：docker compose -f docker-compose.prod.yml --env-file .env.production up -d
# =============================================================================

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=nj_erp
POSTGRES_USER=postgres
POSTGRES_PASSWORD=                          # 必填：強密碼（隨機 32+ 字元）

# ── 後端連線 URL（host 填 Docker 服務名稱 postgres）────────────────────────────
DATABASE_URL=postgresql://postgres:CHANGE_ME@postgres:5432/nj_erp

# ── JWT ───────────────────────────────────────────────────────────────────────
JWT_SECRET=                                 # 必填：openssl rand -hex 32
JWT_ACCESS_EXPIRES_IN=3600
JWT_REFRESH_EXPIRES_IN=2592000

# ── 伺服器 ───────────────────────────────────────────────────────────────────
PORT=3000
# BACKEND_BIND_ADDRESS=127.0.0.1           # 預設僅本機；若使用 Cloudflare Tunnel 維持此值

# ── 公司資訊（報價單 PDF 抬頭）────────────────────────────────────────────────
COMPANY_NAME=NJ Stream
COMPANY_ADDRESS=
COMPANY_PHONE=
COMPANY_EMAIL=
COMPANY_TAX_ID=

# ── Firebase Admin SDK（FCM push 通知）────────────────────────────────────────
# 從 Firebase Console → Project Settings → Service Accounts → 產生私鑰（JSON）
# 將整個 JSON 壓成單行後貼入此變數（換行符用 \n 替換）
# 未填入時 push 通知功能靜默停用，其他功能不受影響
FIREBASE_SERVICE_ACCOUNT=                      # 必填（若啟用 push 通知）

# ── AI Service（Fastify ↔ ai_service 服務間通訊）────────────────────────────
# Fastify 打 ai_service 的內部 URL（Docker 網路內使用服務名稱）
AI_SERVICE_URL=http://ai_service:8000
# 服務間 mutual auth token，≥32 字元：openssl rand -hex 32
AI_SERVICE_INTERNAL_TOKEN=                      # 必填

# ── ai_service 本身的環境變數 ─────────────────────────────────────────────────
# true = 不呼叫 Ollama，回傳固定 fake token stream（CI/測試用，生產設 false）
AI_FAKE_LLM=false
# ai_service 回打 Fastify 的內部 URL
FASTIFY_INTERNAL_URL=http://backend:3000/api/v1
# Ollama 服務位址（與 ai_service 同主機或另一台 GPU 機器）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2:3b
# ChromaDB 資料目錄（對應 docker-compose.prod.yml 的 chroma_data volume）
CHROMA_DB_PATH=/data/chroma
# card_generator.py 使用的唯讀 DB 帳號（不可用 app 主帳號）
DB_READONLY_URL=                                # 必填：postgresql://readonly_user:PWD@postgres:5432/nj_erp

# ── Backup / Restore (scripts/backup_pg.ps1 + restore_pg.ps1) ────────────────
# 執行備份腳本前在 PowerShell 中設定以下變數（不傳入 docker compose）
BACKUP_PASSPHRASE=                              # 必填：≥20 字元強密語（獨立於 DB 密碼）
BACKUP_DIR=C:\Backups\NJ_ERP                   # 備份輸出目錄（Windows 路徑）
POSTGRES_CONTAINER=nj-erp-postgres             # Docker 容器名稱（預設值）